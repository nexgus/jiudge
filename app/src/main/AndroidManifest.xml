<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Only network use: downloading RudyMap/BRouter data from public mirrors (see CLAUDE.md). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Foreground service keeps the ~400 MB first-run download alive across screen-off/background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Background track recording runs as a foreground service of type=location so it keeps the
         GPS subscription alive while the app is backgrounded. Required on Android 14+ for any
         foreground service that uses the location runtime permission. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Long-running background work (map-data download, background track recording) must hold
         PARTIAL_WAKE_LOCK so Doze does not suspend the CPU between fixes / mid-transfer. WifiLock
         does not require its own permission. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Doze ignores wake locks unless the app is exempt from battery optimizations, so a recording
         through a long stationary rest (screen off, device still) would drop fixes. Normal
         (install-time) permission; the actual grant is the system dialog fired by
         ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS from the pre-recording rationale flow. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Runtime-requested on Android 13+ so the download / recording notifications are visible. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Current-location marker on the map (foreground-only) and background track recording
         (foreground service). ACCESS_BACKGROUND_LOCATION is required on Android 10+ for the
         recording service to keep receiving GPS fixes with the app in the background; it must be
         granted via the system settings page ("Always allow"), which the in-app rationale routes
         the user to. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Route plans live in a fixed public folder (Documents/Jiudge) so they survive uninstall and a
         reinstall can re-read them (see CLAUDE.md storage rationale). On Android 11+ this needs All
         files access; on Android 10 and below, legacy WRITE_EXTERNAL_STORAGE. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".JiudgeApp"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jiudge">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:theme="@style/Theme.Jiudge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".core.mapdata.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".core.recording.RecordingService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>

</manifest>
