<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Only network use: downloading RudyMap/BRouter data from public mirrors (see CLAUDE.md). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Foreground service keeps the ~400 MB first-run download alive across screen-off/background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Runtime-requested on Android 13+ so the download progress notification is visible. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Current-location marker on the map. Foreground-only (subscribed while the map is visible,
         dropped on pause); background track recording will add a foreground service separately. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Route plans live in a fixed public folder (Documents/Jiudge) so they survive uninstall and a
         reinstall can re-read them (see CLAUDE.md storage rationale). On Android 11+ this needs All
         files access; on Android 10 and below, legacy WRITE_EXTERNAL_STORAGE. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <application
        android:name=".JiudgeApp"
        android:allowBackup="true"
        android:requestLegacyExternalStorage="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jiudge">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:theme="@style/Theme.Jiudge">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".core.mapdata.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
